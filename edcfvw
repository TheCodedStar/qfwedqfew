		animTracks = {}

		pcall(function() Humanoid.PlatformStand = true end)

		conn = Heartbeat:Connect(function()
			if not TargetTorsoPart or not TargetTorsoPart.Parent then
				detach()
				return
			end

			local offset = CFrame.new(
				Vector3.new(0, 0, 5) + TorsoDebugPos
			) * CFrame.Angles(
				math.rad(TorsoDebugRot.X),
				math.rad(TorsoDebugRot.Y),
				math.rad(TorsoDebugRot.Z)
			)

			RootPart.CFrame = TargetTorsoPart.CFrame * offset
			pcall(function() safeSetHiddenProperty(RootPart, "PhysicsRepRootPart", TargetTorsoPart) end)
			pcall(function()
				RootPart.AssemblyLinearVelocity = Vector3.zero
				RootPart.AssemblyAngularVelocity = Vector3.zero
			end)
		end)

		activeAttachment = { detach = detach }
	end

	local function rebindKey(newKey)
		if inputBeganConn then inputBeganConn:Disconnect() inputBeganConn = nil end
		if inputEndedConn then inputEndedConn:Disconnect() inputEndedConn = nil end

		boundKey = newKey
		keyHeld = false
		if active then detach() end

		inputBeganConn = UserInputService.InputBegan:Connect(function(input, processed)
			if processed then return end
			if input.KeyCode == boundKey then
				keyHeld = true
				if toggleArmed then attach() end
			end
		end)

		inputEndedConn = UserInputService.InputEnded:Connect(function(input)
			if input.KeyCode == boundKey then
				keyHeld = false
				if active then detach() end
			end
		end)
	end

	rebindKey(Enum.KeyCode.E)

	torsoTab:CreateSection("Stand Behind Far")

	torsoTab:CreateInput({
		Name = "Hold Key (default: E)",
		CurrentValue = "E",
		PlaceholderText = "e.g. E, F, G, LeftShift...",
		RemoveTextAfterFocusLost = false,
		Flag = "StandBehindFarKeyInput",
		Callback = function(text)
			local trimmed = text:match("^%s*(.-)%s*$")
			local okKey, keyCode = pcall(function()
				return Enum.KeyCode[trimmed]
			end)
			if okKey and keyCode then
				rebindKey(keyCode)
			end
		end
	})

	torsoTab:CreateToggle({
		Name = "Stand Behind Far (Hold Key)",
		CurrentValue = false,
		Flag = "Attach_StandBehindFar",
		Callback = function(v)
			toggleArmed = v
			if not v and active then
				detach()
			end
			if v and keyHeld then
				attach()
			end
		end
	})
end

