local function createAttachmentToggle(tab, displayName, flagName, positionOffset, rotationOffset, sitAnimationId)
	local conn, TargetHead, TargetPlayer, animTracks
	local active = false

	local function getCFrameOffset()
		local posDebug, rotDebug
		if tab == mainTab then
			posDebug, rotDebug = HeadDebugPos, HeadDebugRot
		elseif tab == torsoTab then
			posDebug, rotDebug = TorsoDebugPos, TorsoDebugRot
		elseif tab == armsTab then
			posDebug, rotDebug = ArmsDebugPos, ArmsDebugRot
		else
			posDebug, rotDebug = HeadDebugPos, HeadDebugRot
		end

		local totalRot = Vector3.new(
			(rotationOffset.X or 0) + (rotDebug and rotDebug.X or 0),
			(rotationOffset.Y or 0) + (rotDebug and rotDebug.Y or 0),
			(rotationOffset.Z or 0) + (rotDebug and rotDebug.Z or 0)
		)
		local totalPos = (positionOffset or Vector3.new(0,0,0)) + (posDebug or Vector3.new(0,0,0))

		return CFrame.new(totalPos) * CFrame.Angles(
			math.rad(totalRot.X),
			math.rad(totalRot.Y),
			math.rad(totalRot.Z)
		)
	end

	local function detach()
		if conn then conn:Disconnect() conn = nil end
		TargetHead = nil
		TargetPlayer = nil

		if animTracks then
			for _, t in ipairs(animTracks) do
				pcall(function() if t and t.Stop then t:Stop() end end)
			end
			animTracks = nil
		end

		if RootPart then
			safeSetHiddenProperty(RootPart, "PhysicsRepRootPart", nil)
			RootPart.AssemblyLinearVelocity = Vector3.zero
			RootPart.AssemblyAngularVelocity = Vector3.zero
		end

		if Humanoid then
			Humanoid.PlatformStand = false
		end

		active = false
		if activeAttachment and activeAttachment.detach == detach then
			activeAttachment = nil
		end
	end

	local function normalizeAnimList(raw)
		if type(raw) == "string" then
			return { raw }
		elseif type(raw) ~= "table" then
			return {}
		end
		if #raw >= 2 and type(raw[1]) == "string" and type(raw[2]) == "number" and (#raw == 2 or type(raw[3]) ~= "string") then
			return { { raw[1], raw[2] } }
		end
		return raw
	end

	local function attach(player)
		if not player or not player.Character then return end

		if active and TargetPlayer == player then
			detach()
			return
		end

		if activeAttachment and activeAttachment.detach ~= detach then
			detachActive()
		end

		refreshCharacterRefs()
		if not Humanoid or not RootPart then return end

		local head = player.Character:FindFirstChild("Head")
		if not head then return end

		TargetHead = head
		TargetPlayer = player
		active = true

		local ids = normalizeAnimList(sitAnimationId)
		animTracks = {}

		for _, entry in ipairs(ids) do
			local id, speed
			if type(entry) == "table" then
				id = entry[1]
				speed = entry[2]
			else
				id = entry
			end
			if type(id) == "string" then
				pcall(function()
					local track = safeLoadAnim(Humanoid, id)
					pcall(function() if track and track.Priority then track.Priority = Enum.AnimationPriority.Action end end)
					if track then
						if type(speed) == "number" then
							pcall(function() track.PlaybackSpeed = speed end)
						end
						table.insert(animTracks, track)
						pcall(function() track:Play() end)
						if type(speed) == "number" then
							pcall(function() track.PlaybackSpeed = speed end)
						end
					end
				end)
			end
		end

		pcall(function() Humanoid.PlatformStand = true end)

		conn = Heartbeat:Connect(function()
			if not TargetHead or not TargetHead.Parent then
				detach()
				return
			end

			local desiredCFrame = TargetHead.CFrame * getCFrameOffset()
			RootPart.CFrame = desiredCFrame
			safeSetHiddenProperty(RootPart, "PhysicsRepRootPart", TargetHead)
			RootPart.AssemblyLinearVelocity = Vector3.zero
			RootPart.AssemblyAngularVelocity = Vector3.zero
		end)

		activeAttachment = { detach = detach }
	end

	tab:CreateToggle({
		Name = displayName,
		CurrentValue = false,
		Flag = flagName,
		Callback = function(v)
			local key = tabKeyName(tab)
			local list = matchingPlayersByTab[key] or {}
			if v and list[1] then
				attach(list[1])
			else
				detach()
			end
		end
	})
end

