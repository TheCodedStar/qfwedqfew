end

local function updateMatchingForTab(tab, text)
	local key = tabKeyName(tab)
	local search = (text or ""):lower()
	local t = {}
	for _, plr in pairs(Players:GetPlayers()) do
		local n = (plr.Name or ""):lower()
		local d = (plr.DisplayName or ""):lower()
		if n:find(search, 1, true) or d:find(search, 1, true) then
			table.insert(t, plr)
		end
	end
	matchingPlayersByTab[key] = t
end

