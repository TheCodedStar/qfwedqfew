local function createDebugControlsForTab(tab, title)
	tab:CreateSection(title .. " Debug")
	local offsetLabel
	pcall(function()
		offsetLabel = tab:CreateLabel({
			Text = string.format("Pos: (%.2f, %.2f, %.2f)  Rot: (%.1f, %.1f, %.1f)", 0,0,0, 0,0,0)
		})
	end)

	local plusX, plusY, plusZ = 0,0,0
	local minusX, minusY, minusZ = 0,0,0
	local plusRotX, plusRotY, plusRotZ = 0,0,0
	local minusRotX, minusRotY, minusRotZ = 0,0,0

	local function recalc()
		local pos = Vector3.new((plusX or 0) - (minusX or 0), (plusY or 0) - (minusY or 0), (plusZ or 0) - (minusZ or 0))
		local rot = Vector3.new((plusRotX or 0) - (minusRotX or 0), (plusRotY or 0) - (minusRotY or 0), (plusRotZ or 0) - (minusRotZ or 0))

		if tab == mainTab then
			HeadDebugPos, HeadDebugRot = pos, rot
		elseif tab == torsoTab then
			TorsoDebugPos, TorsoDebugRot = pos, rot
		elseif tab == armsTab then
			ArmsDebugPos, ArmsDebugRot = pos, rot
		end

		if offsetLabel and offsetLabel.SetText then
			pcall(function()
				offsetLabel:SetText(string.format("Pos: (%.2f, %.2f, %.2f)  Rot: (%.1f, %.1f, %.1f)",
					pos.X, pos.Y, pos.Z, rot.X, rot.Y, rot.Z))
			end)
		end
	end

	tab:CreateSection("+ XYZ")
	local sPlusX, sPlusY, sPlusZ
	pcall(function()
		sPlusX = tab:CreateSlider({ Name = "+ X", Range = { 0, 10 }, Increment = 0.1, CurrentValue = 0, Callback = function(v) plusX = v or 0; recalc() end })
		sPlusY = tab:CreateSlider({ Name = "+ Y", Range = { 0, 10 }, Increment = 0.1, CurrentValue = 0, Callback = function(v) plusY = v or 0; recalc() end })
		sPlusZ = tab:CreateSlider({ Name = "+ Z", Range = { 0, 10 }, Increment = 0.1, CurrentValue = 0, Callback = function(v) plusZ = v or 0; recalc() end })
	end)

	tab:CreateSection("- XYZ")
	local sMinusX, sMinusY, sMinusZ
	pcall(function()
		sMinusX = tab:CreateSlider({ Name = "- X", Range = { 0, 10 }, Increment = 0.1, CurrentValue = 0, Callback = function(v) minusX = v or 0; recalc() end })
		sMinusY = tab:CreateSlider({ Name = "- Y", Range = { 0, 10 }, Increment = 0.1, CurrentValue = 0, Callback = function(v) minusY = v or 0; recalc() end })
		sMinusZ = tab:CreateSlider({ Name = "- Z", Range = { 0, 10 }, Increment = 0.1, CurrentValue = 0, Callback = function(v) minusZ = v or 0; recalc() end })
	end)

	tab:CreateSection("+ Rotations")
	local sPlusRX, sPlusRY, sPlusRZ
	pcall(function()
		sPlusRX = tab:CreateSlider({ Name = "+ Rot X", Range = { 0, 180 }, Increment = 1, CurrentValue = 0, Callback = function(v) plusRotX = v or 0; recalc() end })
		sPlusRY = tab:CreateSlider({ Name = "+ Rot Y", Range = { 0, 180 }, Increment = 1, CurrentValue = 0, Callback = function(v) plusRotY = v or 0; recalc() end })
		sPlusRZ = tab:CreateSlider({ Name = "+ Rot Z", Range = { 0, 180 }, Increment = 1, CurrentValue = 0, Callback = function(v) plusRotZ = v or 0; recalc() end })
	end)

	tab:CreateSection("- Rotations")
	local sMinusRX, sMinusRY, sMinusRZ
	pcall(function()
		sMinusRX = tab:CreateSlider({ Name = "- Rot X", Range = { 0, 180 }, Increment = 1, CurrentValue = 0, Callback = function(v) minusRotX = v or 0; recalc() end })
		sMinusRY = tab:CreateSlider({ Name = "- Rot Y", Range = { 0, 180 }, Increment = 1, CurrentValue = 0, Callback = function(v) minusRotY = v or 0; recalc() end })
		sMinusRZ = tab:CreateSlider({ Name = "- Rot Z", Range = { 0, 180 }, Increment = 1, CurrentValue = 0, Callback = function(v) minusRotZ = v or 0; recalc() end })
	end)

	for _, s in pairs({sPlusX, sPlusY, sPlusZ, sMinusX, sMinusY, sMinusZ, sPlusRX, sPlusRY, sPlusRZ, sMinusRX, sMinusRY, sMinusRZ}) do
		if s and s.SetValue then pcall(function() s:SetValue(0) end) end
	end

	recalc()
end

