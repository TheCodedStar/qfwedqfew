local function safeSetHiddenProperty(obj, prop, value)
	if type(sethiddenproperty) == "function" then
		pcall(function()
			sethiddenproperty(obj, prop, value)
		end)
	end
end

local function safeLoadAnim(humanoid, assetId)
	local anim = Instance.new("Animation")
	anim.AnimationId = assetId

	local okLoad, track = pcall(function()
		return humanoid:LoadAnimation(anim)
	end)

	if okLoad and track then
		track.Looped = true

		local originalPlay = track.Play
		function track:Play(...)
			originalPlay(self, ...)
			if assetId == "rbxassetid://179224234" then
				pcall(function()
					self:AdjustSpeed(2)
				end)
			end
		end

		return track
	end

	return {
		Looped = true,
		Play = function() end,
		Stop = function() end
	}
end

